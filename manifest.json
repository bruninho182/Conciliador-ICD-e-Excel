{
  "manifest_version": 3,
  "name": "Conciliador ICD Por Bruno Ferreira",
  "version": "1.1",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["activeTab", "scripting", "sidePanel", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Abrir Conciliador"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["*://report.ingressocomdesconto.com.br/*", "*://ingressocomdesconto.com.br/*"],
      "js": ["content.js"]
    }
  ]
}