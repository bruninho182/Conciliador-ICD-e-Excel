{
  "manifest_version": 3,
  "name": "Conciliador ICD e Excel. By: Bruno Ferreira",
  "version": "1.0",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["*://report.ingressocomdesconto.com.br/*", "*://ingressocomdesconto.com.br/*"],
      "js": ["content.js"]
    }
  ]
}